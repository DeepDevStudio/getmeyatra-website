<%
const content = `
<section style="padding: 150px 0 80px; background: var(--bg-light);">
    <div class="container">
        <div class="section-header">
            <span class="section-tag">Contact</span>
            <h1>Get In <span class="gradient-text">Touch</span></h1>
            <p>We'd love to hear from you. Let's plan your next adventure!</p>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; max-width: 1000px; margin: 0 auto;">
            <div>
                <form style="background: white; padding: 40px; border-radius: 20px; box-shadow: var(--shadow);">
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; margin-bottom: 8px; font-weight: 600;">Name</label>
                        <input type="text" style="width: 100%; padding: 14px; border: 2px solid #E5E7EB; border-radius: 12px; font-size: 16px;">
                    </div>
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; margin-bottom: 8px; font-weight: 600;">Email</label>
                        <input type="email" style="width: 100%; padding: 14px; border: 2px solid #E5E7EB; border-radius: 12px; font-size: 16px;">
                    </div>
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; margin-bottom: 8px; font-weight: 600;">Message</label>
                        <textarea rows="5" style="width: 100%; padding: 14px; border: 2px solid #E5E7EB; border-radius: 12px; font-size: 16px;"></textarea>
                    </div>
                    <button type="submit" class="btn-primary" style="width: 100%; justify-content: center;">Send Message</button>
                </form>
            </div>
            <div>
                <div style="background: white; padding: 40px; border-radius: 20px; box-shadow: var(--shadow);">
                    <h3 style="margin-bottom: 30px;">Contact Information</h3>
                    <div style="display: flex; gap: 20px; margin-bottom: 30px; align-items: center;">
                        <i class="fas fa-map-marker-alt" style="font-size: 28px; color: var(--primary);"></i>
                        <div>
                            <h4>Address</h4>
                            <p style="color: var(--text-gray);">123 Travel Street, City, Country</p>
                        </div>
                    </div>
                    <div style="display: flex; gap: 20px; margin-bottom: 30px; align-items: center;">
                        <i class="fas fa-phone" style="font-size: 28px; color: var(--primary);"></i>
                        <div>
                            <h4>Phone</h4>
                            <p style="color: var(--text-gray);">+1 234 567 890</p>
                        </div>
                    </div>
                    <div style="display: flex; gap: 20px; align-items: center;">
                        <i class="fas fa-envelope" style="font-size: 28px; color: var(--primary);"></i>
                        <div>
                            <h4>Email</h4>
                            <p style="color: var(--text-gray);">info@getmeyatra.com</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
`;
%>
<%- include('layout', { title: 'Contact Us - GetMeYatra', content: content }) %>
